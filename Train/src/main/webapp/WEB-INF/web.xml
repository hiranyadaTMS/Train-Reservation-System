<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
	<welcome-file-list>
		<welcome-file>home.jsp</welcome-file>
	</welcome-file-list>
	
    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>com.user.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/log</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CustomerInsert</servlet-name>
        <servlet-class>com.user.CustomerInsert</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerInsert</servlet-name>
        <url-pattern>/CustomerInsert</url-pattern>
    </servlet-mapping>

	<servlet>
        <servlet-name>updateCustomer</servlet-name>
        <servlet-class>com.user.UpdateCustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>updateCustomer</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>deleteCustomer</servlet-name>
        <servlet-class>com.user.deleteCustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>deleteCustomer</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>
    
    
    <servlet>
        <servlet-name>ticketInsert</servlet-name>
        <servlet-class>com.bookticket.insertTicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ticketInsert</servlet-name>
        <url-pattern>/ticketInsert</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>updateTicket</servlet-name>
        <servlet-class>com.bookticket.updateTicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>updateTicket</servlet-name>
        <url-pattern>/updateTicket</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>deleteTicket</servlet-name>
        <servlet-class>com.bookticket.deleteTicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>deleteTicket</servlet-name>
        <url-pattern>/deleteTicket</url-pattern>
    </servlet-mapping>
    
    
    
    <!-- insert payment --> 
		<servlet>
			<servlet-name>PaymentInsert</servlet-name>
			<servlet-class>com.payment.PaymentInsertServlet</servlet-class> 
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>PaymentInsert</servlet-name>
		 	<url-pattern>/pay</url-pattern> <!-- action to the payment insert form -->
		 </servlet-mapping>
		 
		 <servlet>
			<servlet-name>PaymentView</servlet-name>
			<servlet-class>com.payment.PaymentViewServlet</servlet-class> <!-- match the servlet -->
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>PaymentView</servlet-name>
		 	<url-pattern>/view</url-pattern> <!-- action to the view form -->
		 </servlet-mapping>
		 <!-- update and delete of payment -->
		 <servlet>
			  <servlet-name>PaymentUpdate</servlet-name>
			<servlet-class>com.payment.UpdatePaymentServlet</servlet-class>  
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>PaymentUpdate</servlet-name>
		 	<url-pattern>/updatepayment</url-pattern>  
		 </servlet-mapping>
		 
		<servlet>
			  <servlet-name>PaymentDelete</servlet-name>
			<servlet-class>com.payment.PaymentDeleteServlet</servlet-class>  
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>PaymentDelete</servlet-name>
		 	<url-pattern>/deletepayment</url-pattern>  
		 </servlet-mapping>
		
		
		<servlet>
			<servlet-name>InquiryInsert</servlet-name>
			<servlet-class>com.inquiry.inquiryInsert</servlet-class> 
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>InquiryInsert</servlet-name>
		 	<url-pattern>/insertInquiry</url-pattern> <!-- action to the payment insert form -->
		 </servlet-mapping>
		 
		<servlet>
			<servlet-name>InquiryUpdate</servlet-name>
			<servlet-class>com.inquiry.updateInqServlet</servlet-class> 
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>InquiryUpdate</servlet-name>
		 	<url-pattern>/updateInquiry</url-pattern> <!-- action to the payment insert form -->
		 </servlet-mapping>
		
		<servlet>
			<servlet-name>InquiryDelete</servlet-name>
			<servlet-class>com.inquiry.DeleteinqServlet</servlet-class> 
		</servlet>
		
		<servlet-mapping> 
		 	<servlet-name>InquiryDelete</servlet-name>
		 	<url-pattern>/deleteInquiry</url-pattern> <!-- action to the payment insert form -->
		 </servlet-mapping>
		 
		 
		 <servlet>
        <servlet-name>adminlogin</servlet-name>
        <servlet-class>com.admin.AdminLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>adminlogin</servlet-name>
        <url-pattern>/adminlog</url-pattern>
    </servlet-mapping>
</web-app>